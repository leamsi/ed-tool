#!/usr/bin/env python3
"""ed-tool — reference-based line editor."""

import argparse
import binascii
import os
import sys
import tempfile


def _compute_crc(line):
    """Return the CRC-CCITT (binascii.crc_hqx) of a line over latin-1 bytes."""
    return binascii.crc_hqx(line.encode('latin-1', errors='replace'), 0)


def parse_ref(ref):
    """Parse a 'lineno:4hex' reference string.

    Returns (lineno: int, hash: str) or exits with a diagnostic message.
    """
    if ':' not in ref:
        sys.stderr.write(f'ed-tool: invalid reference format (expected lineno:hash): {ref}\n')
        sys.exit(1)
    lineno_str, hash_str = ref.rsplit(':', 1)
    try:
        lineno = int(lineno_str)
    except ValueError:
        sys.stderr.write(f'ed-tool: invalid line number in reference: {ref}\n')
        sys.exit(1)
    if len(hash_str) != 4 or not all(c in '0123456789abcdefABCDEF' for c in hash_str):
        sys.stderr.write(f'ed-tool: hash must be exactly 4 hex digits: {ref}\n')
        sys.exit(1)
    return lineno, hash_str.lower()


def _write_file(path, lines):
    """Atomically replace the contents of path with lines.

    Writes via a tempfile in the same directory then uses os.replace
    to achieve an atomic swap on POSIX systems. Preserves the original
    file's permission bits.
    """
    dir_path = os.path.dirname(path) or '.'
    # Preserve original permission bits (if file exists)
    original_mode = None
    if os.path.exists(path):
        original_mode = os.stat(path).st_mode & 0o777
    fd, tmp = tempfile.mkstemp(dir=dir_path, suffix='.tmp')
    try:
        with os.fdopen(fd, 'w', encoding='utf-8') as fh:
            fh.writelines(lines)
        if original_mode is not None:
            os.chmod(tmp, original_mode)
        os.replace(tmp, path)
    except Exception:
        if os.path.exists(tmp):
            os.unlink(tmp)
        raise


def do_read(args):
    """Read a file and print each line with a lineno:hash| prefix."""
    try:
        with open(args.file, 'r', encoding='utf-8', errors='replace') as f:
            content_lines = f.readlines()
    except OSError as e:
        sys.stderr.write(f'ed-tool: {e}\n')
        sys.exit(1)

    for lineno, line in enumerate(content_lines, start=1):
        crc = _compute_crc(line)
        content = line.rstrip('\n')
        print(f'{lineno}:{crc:04x}|{content}')


def do_append(args):
    """Append a new line after the referenced line.

    The ref (lineno:hash) is validated before any mutation.
    """
    lineno, expected_hash = parse_ref(args.ref)
    content = args.content
    if content is None:
        content = sys.stdin.read().rstrip('\n')
        if not content:
            return  # empty stdin = no-op

    try:
        with open(args.file, 'r', encoding='utf-8', errors='replace') as f:
            lines = f.readlines()
    except OSError as e:
        sys.stderr.write(f'ed-tool: {e}\n')
        sys.exit(1)

    if not (1 <= lineno <= len(lines)):
        sys.stderr.write(
            f'ed-tool: line number {lineno} is out of range '
            f'(file has {len(lines)} lines)\n'
        )
        sys.exit(1)

    actual_hash = format(_compute_crc(lines[lineno - 1]), '04x')
    if actual_hash != expected_hash:
        sys.stderr.write(
            f'ed-tool: hash mismatch on line {lineno}: '
            f'expected {expected_hash}, got {actual_hash}\n'
        )
        sys.exit(1)

    new_line = content + '\n'
    lines.insert(lineno, new_line)
    _write_file(args.file, lines)



            f'expected {expected_hash}, got {actual_hash}\n'
        )
        sys.exit(1)

    lines[lineno - 1] = content + '\n'
    _write_file(args.file, lines)


if __name__ == '__main__':
    parser = argparse.ArgumentParser(prog='ed-tool')
    parser.add_argument('--version', action='version', version='ed-tool 1.0.0')
    parser.formatter_class = argparse.RawDescriptionHelpFormatter
    parser.epilog = '''workflow:
  ed-tool r file.txt               # see lines with hash refs
  ed-tool a file.txt 1:abcd <<EOF  # append after line 1
new line
EOF
  ed-tool i file.txt 2:bcde <<EOF   # insert before line 2
another line
EOF
  ed-tool c file.txt 3:cdef <<EOF   # change line 3
replaced
EOF
  ed-tool d file.txt 4:def0        # delete line 4'''
    subparsers = parser.add_subparsers(dest='command', parser_class=argparse.ArgumentParser)

    # read
    p_r = subparsers.add_parser('r', help='read a file with hash prefixes')
    p_r.formatter_class = argparse.RawDescriptionHelpFormatter
    p_r.add_argument('file')
    p_r.epilog = '''examples:
  ed-tool r file.txt              # show lines with lineno:hash prefixes
  cat file.txt | ed-tool r -     # read from stdin'''

    # append
    p_a = subparsers.add_parser('a', help='append a line after the referenced line')
    p_a.formatter_class = argparse.RawDescriptionHelpFormatter
    p_a.add_argument('file')
    p_a.add_argument('ref', help='lineno:hash of the line to append after')
    p_a.add_argument('-c', '--content', dest='content', help='new line content (reads stdin if omitted)')
    p_a.epilog = '''examples:
  ed-tool a file.txt 1:abcd -c "new line"       # append after line 1
  echo "new line" | ed-tool a file.txt 1:abcd  # same, via stdin
  <<EOF ed-tool a file.txt 1:abcd              # heredoc
new line
EOF'''

    # insert
    p_i = subparsers.add_parser('i', help='insert a line before the referenced line')
    p_i.formatter_class = argparse.RawDescriptionHelpFormatter
    p_i.add_argument('file')
    p_i.add_argument('ref', help='lineno:hash of the line to insert before')
    p_i.add_argument('-c', '--content', dest='content', help='new line content (reads stdin if omitted)')
    p_i.epilog = '''examples:
  ed-tool i file.txt 1:abcd -c "new line"       # insert before line 1
  echo "new line" | ed-tool i file.txt 1:abcd   # same, via stdin
  <<EOF ed-tool i file.txt 1:abcd               # heredoc
new line
EOF'''

    # delete
    p_d = subparsers.add_parser('d', help='delete the referenced line')
    p_d.formatter_class = argparse.RawDescriptionHelpFormatter
    p_d.add_argument('file')
    p_d.add_argument('ref', help='lineno:hash of the line to delete')
    p_d.epilog = '''examples:
  ed-tool d file.txt 1:abcd        # delete line 1 (hash must match)
  ed-tool r file.txt               # get current refs first'''

    # change
    p_c = subparsers.add_parser('c', help='change the content of the referenced line')
    p_c.formatter_class = argparse.RawDescriptionHelpFormatter
    p_c.add_argument('file')
    p_c.add_argument('ref', help='lineno:hash of the line to change')
    p_c.add_argument('-c', '--content', dest='content', help='new line content (reads stdin if omitted)')
    p_c.epilog = '''examples:
  ed-tool c file.txt 1:abcd -c "replacement"       # replace line 1
  echo "replacement" | ed-tool c file.txt 1:abcd  # same, via stdin
  <<EOF ed-tool c file.txt 1:abcd                 # heredoc
replacement
EOF'''

    args = parser.parse_args()
    if args.command == 'r':
        do_read(args)
    elif args.command == 'a':
        do_append(args)
    elif args.command == 'i':
        do_insert(args)
    elif args.command == 'd':
        do_delete(args)
    elif args.command == 'c':
        do_change(args)
    else:
        parser.print_help()

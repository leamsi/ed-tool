    """Change the content of the referenced line.

    The ref (lineno:hash) is validated before any mutation.
    """
    lineno, expected_hash = parse_ref(args.ref)
    content = args.content
    if content is None:
        content = sys.stdin.read().rstrip('\n')
        if not content:
            return  # empty stdin = no-op

    try:
        with open(args.file, 'r', encoding='utf-8', errors='replace') as f:
